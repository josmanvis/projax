{
  "name": "projax-workspace",
  "version": "3.3.66",
  "packageManager": "pnpm@10.25.0",
  "description": "projax - Cross-platform project management dashboard with CLI and web interface",
  "author": "Jose Viscasillas <viscasillas@me.com>",
  "repostory": {
    "type": "git",
    "url": "https://github.com/josetwentyfour/projax.git"
  },
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:core": "pnpm --filter projax-core run build",
    "build:api": "pnpm --filter projax-api run build",
    "build:cli": "pnpm --filter projax run build",
    "build:desktop": "pnpm --filter projax-desktop run build",
    "build:prxi": "pnpm --filter projax-prxi run build",
    "build:docsite": "pnpm --filter projax-docsite run build",
    "build:vscode-extension": "pnpm --filter projax-vscode run build",
    "dev:desktop": "pnpm --filter projax-desktop run dev",
    "dev:api": "pnpm --filter projax-api run dev",
    "dev:prxi": "pnpm --filter projax-prxi run dev",
    "dev:docsite": "pnpm --filter projax-docsite run start",
    "dev:vscode-extension": "pnpm --filter projax-vscode run watch",
    "test": "turbo run test",
    "test:api": "pnpm --filter projax-api run test",
    "test:cli": "pnpm --filter projax run test",
    "test:core": "pnpm --filter projax-core run test",
    "test:watch:api": "pnpm --filter projax-api run test:watch",
    "test:watch:cli": "pnpm --filter projax run test:watch",
    "test:watch:core": "pnpm --filter projax-core run test:watch",
    "test:coverage:api": "pnpm --filter projax-api run test:coverage",
    "test:coverage:cli": "pnpm --filter projax run test:coverage",
    "test:coverage:core": "pnpm --filter projax-core run test:coverage",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint-staged": "lint-staged",
    "clean": "pnpm --filter '{packages/*}' run clean && rm -rf node_modules",
    "postinstall": "pnpm run build:core && pnpm run build:api",
    "version": "node scripts/bump-version.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "release": "node scripts/release.js",
    "release:yes": "node scripts/release.js patch -y",
    "release:docsite": "cd packages/docsite && pnpm run deploy",
    "release:patch": "echo 'patch' | node scripts/release.js",
    "release:minor": "echo 'minor' | node scripts/release.js",
    "release:major": "echo 'major' | node scripts/release.js",
    "use:local": "sudo pnpm uninstall -g projax && sudo pnpm link --global packages/cli && zsh",
    "use:npm": "sudo pnpm uninstall -g projax && sudo pnpm install -g projax && zsh"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "turbo": "^2.6.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
