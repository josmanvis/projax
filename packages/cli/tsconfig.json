{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./src",
    "jsx": "react",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      // NOTE: projax-core is a workspace alias pointing to local packages/core
      // This path mapping is for TypeScript compilation only (points to source)
      // At runtime, pnpm resolves "projax-core" via workspace:* dependency
      "projax-core": ["../core/src/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/prxi.tsx"]
}

